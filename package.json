{
  "name": "mogulgame_app_rn",
  "version": "1.0.53",
  "displayName": "Starter App",
  "private": true,
  "scripts": {
    "clean:metro": "rm -rf $TMPDIR/metro-* $TMPDIR/haste-map-* || true",
    "prestart": "node scripts/merge-env.js && bun run clean:metro",
    "start": "ENVFILE=.env.merged react-native start --port 8090",
    "preandroid": "node scripts/merge-env.js && bun run clean:metro",
    "android": "ENVFILE=.env.merged react-native run-android --port 8090",
    "preios": "node scripts/merge-env.js && bun run clean:metro",
    "ios": "ENVFILE=.env.merged react-native run-ios --port 8090",
    "premacos": "node scripts/merge-env.js && bun run clean:metro",
    "macos": "ENVFILE=.env.merged react-native run-macos --port 8090",
    "prewindows": "node scripts/merge-env.js",
    "windows": "ENVFILE=.env.merged npx @react-native-community/cli run-windows --port 8090",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "localize": "SCRIPT=$(mktemp) && curl -fsSL https://raw.githubusercontent.com/johnqh/workflows/main/scripts/localize_batch.cjs -o $SCRIPT && node $SCRIPT ./assets/locales https://api.whisperly.dev/api/v1/translate/jie9cytr/starter --word-limit 40 && rm -f $SCRIPT && prettier . --write",
    "verify": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-firebase/perf": "^23.8.8",
    "@react-native-firebase/remote-config": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.1",
    "@sudobility/auth_lib": "^0.0.76",
    "@sudobility/building_blocks_rn": "^0.0.37",
    "@sudobility/design": "^1.1.30",
    "@sudobility/di": "^1.5.56",
    "@sudobility/di_rn": "^0.1.90",
    "@sudobility/mogulgame_client": "^0.0.28",
    "@sudobility/mogulgame_lib": "^0.0.26",
    "@sudobility/mogulgame_types": "^0.0.20",
    "@sudobility/types": "^1.9.62",
    "@tanstack/react-query": "^5.90.19",
    "expo": "~54.0.32",
    "expo-status-bar": "^3.0.9",
    "firebase": "^11.6.0",
    "i18next": "^25.8.0",
    "react": "19.1.0",
    "react-i18next": "^16.5.3",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-heroicons": "^4.0.0",
    "react-native-localize": "^3.6.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.15.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/eslint-config": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@types/jest": "^29.5.13",
    "@types/react": "~19.1.0",
    "babel-jest": "^29.6.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^54.0.10",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-macos": "^0.81.2",
    "react-native-windows": "^0.81.4",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudobility-usf/starter_app_rn.git"
  }
}
